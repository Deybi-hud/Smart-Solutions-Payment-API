# MercadoPago
MP_ACCESS_TOKEN=APP_USR-tu-access-token-aqui

# URL del front, usada para las back_urls de MercadoPago
FRONTEND_URL=http://localhost:5173

# CORS origins separadas por coma
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4200

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=payments_db
DB_USER=postgres
DB_PASSWORD=tu_password
DB_SSL=false

# Servidor
PORT=3000
NODE_ENV=development
